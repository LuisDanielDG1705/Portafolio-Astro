---
const { siteMeta, socialLinks } = Astro.props;
---
<header id="header">
  <div class="header-content">
    <img src={siteMeta.avatarUrl} alt={siteMeta.title} class="avatar" />
    <h1>{siteMeta.title}</h1>
    <p class="title">Desarrollador Multiplataforma | Estudiante</p>
    <p class="bio">Estudiante de Desarrollo Multiplataforma con afinidad en desarrollo web y de backend con Python.</p>
    <nav class="social-nav">
      <ul>
        {socialLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`icon ${link.iconClass}`}
              title={link.label}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              <span class="label">{link.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
