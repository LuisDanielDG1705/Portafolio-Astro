---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';
const title = site.title;
---
<BaseLayout title={title} description={site.description}>
  <Hero heading={site.hero.heading} subtitle={site.hero.subtitle} socialLinks={site.socialLinks} />
  <Footer
    copyright={site.copyright}
    designText={site.designText}
    designUrl={site.designUrl}
    designLabel={site.designLabel}
  />
</BaseLayout>
